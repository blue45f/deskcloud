{
  "name": "deskcloud",
  "private": true,
  "version": "0.0.0",
  "description": "DeskCloud SaaS 패밀리 통합 모노레포 (platform + desks)",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test --concurrency=1",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run build && pnpm run test",
    "build:platform": "turbo run build --filter=\"./platform/*\"",
    "build:desks": "turbo run build --filter=\"./desks/**\"",
    "build:developer-desks": "turbo run build --filter=@desk/seo-gateway --filter=@desk/remote-devtools",
    "typecheck:developer-desks": "turbo run typecheck --filter=@desk/seo-gateway --filter=@desk/remote-devtools",
    "test:developer-desks": "turbo run test --concurrency=1 --filter=@desk/seo-gateway --filter=@desk/remote-devtools",
    "verify:developer-desks": "pnpm run typecheck:developer-desks && pnpm run build:developer-desks && pnpm run test:developer-desks",
    "dev:seo-gateway": "pnpm --filter @spa-seo-gateway/gateway run dev",
    "dev:remote-devtools:internal": "pnpm --filter @desk/remote-devtools run start:internal:dev",
    "dev:remote-devtools:external": "pnpm --filter @desk/remote-devtools run start:external:dev",
    "build:sdk": "turbo run build --filter=\"@heejun/deskcloud\"",
    "deploy": "pnpm --filter @deskcloud/deploy run deploy",
    "deploy:no-build": "pnpm --filter @deskcloud/deploy run deploy:no-build",
    "compose:config": "pnpm --filter @deskcloud/deploy run compose:config",
    "compose:ps": "pnpm --filter @deskcloud/deploy run compose:ps",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@heejun/eslint-config": "^5.0.0",
    "@heejun/prettier-config": "^3.0.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "turbo": "^2.5.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
