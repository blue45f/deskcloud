{
  "name": "@heejun/deskcloud",
  "version": "0.1.0",
  "description": "Unified, browser-first, zero-runtime-dep, tree-shakeable TypeScript SDK for the DeskCloud SaaS family. Public (pk_) clients from '@heejun/deskcloud', admin (sk_) clients from '@heejun/deskcloud/server'.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": "heejun",
  "keywords": [
    "deskcloud",
    "sdk",
    "saas",
    "tree-shakeable",
    "browser",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "audit:security": "pnpm audit --audit-level high --ignore GHSA-2p57-rm9w-gvfp",
    "lint:security": "pnpm run audit:security",
    "verify:push": "pnpm run lint:security",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup",
    "turbo:build": "pnpm exec turbo run build",
    "turbo:typecheck": "pnpm exec turbo run typecheck"
  },
  "peerDependencies": {
    "socket.io-client": ">=4"
  },
  "peerDependenciesMeta": {
    "socket.io-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.5.1",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.4.0"
}
