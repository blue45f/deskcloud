{
  "name": "@communitydesk/widget",
  "version": "0.1.0",
  "private": true,
  "description": "CommunityDesk 임베드 위젯 — 호스트 앱에 게시판/카페를 띄우는 자급식(self-contained) React 컴포넌트. <CommunityBoard>(글 목록·정렬·태그필터 → 글 열기 → 중첩 댓글 → 글/댓글 작성·반응)와 <CommunityFeed>(최근 글 요약). 바닐라 IIFE 로더(window.CommunityDesk)도 제공. 의존성은 react(peer)뿐, 외부 CSS 프레임워크 0.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vanilla": {
      "types": "./dist/vanilla.d.ts",
      "import": "./dist/vanilla.js",
      "require": "./dist/vanilla.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && vite build --config vite.iife.config.ts",
    "build:demo": "vite build --config demo/vite.config.ts",
    "dev": "tsup --watch",
    "dev:demo": "vite --config demo/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist demo/dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@communitydesk/sdk": "workspace:*",
    "@communitydesk/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
