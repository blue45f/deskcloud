{
  "name": "@moderationdesk/widget",
  "version": "0.1.0",
  "private": true,
  "description": "ModerationDesk 임베드 위젯 — 콘텐츠에 붙는 접근성 '신고' 버튼(<ReportButton>) + 사유 선택 다이얼로그, 그리고 클라이언트 사전검사 훅(<ModerationBadge>/useModerationCheck). publishable 키(pk_)로 동작. React 컴포넌트 + 바닐라 IIFE 로더. 의존성은 react(peer)뿐, 외부 CSS 프레임워크 0.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vanilla": {
      "types": "./dist/vanilla.d.ts",
      "import": "./dist/vanilla.js",
      "require": "./dist/vanilla.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && vite build --config vite.iife.config.ts",
    "build:demo": "vite build --config demo/vite.config.ts",
    "dev": "tsup --watch",
    "dev:demo": "vite --config demo/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist demo/dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@moderationdesk/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
