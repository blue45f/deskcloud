{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "corepack pnpm@11.4.0 install --no-frozen-lockfile --ignore-scripts",
  "buildCommand": "corepack pnpm@11.4.0 --filter @desk/web... build",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://16.176.210.195.nip.io/platform/api/:path*"
    },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
