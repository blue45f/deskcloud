{
  "name": "@desk/core",
  "version": "0.1.0",
  "private": true,
  "description": "DeskCloud 멀티테넌트 코어 — ApiKey 발급/검증/회전 · CORS allowlist · UsageMeter(프레임워크 무관) + NestJS 어댑터(AdminTokenGuard·PublishableKeyGuard·SecretKeyGuard·프로바이더).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nest": {
      "types": "./dist/nest.d.ts",
      "import": "./dist/nest.js",
      "require": "./dist/nest.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@desk/shared": "workspace:*",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.24",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
