# ──────────────────────────────────────────────────────────────────────
# Client environment variables (Vite — VITE_* are exposed to the browser)
# ──────────────────────────────────────────────────────────────────────

# ── Mode 1: Public demo (no backend required) ──
# Uncomment to force demo mode for all visitors (seed data, no backend).
# VITE_FORCE_DEMO=true

# ── Mode 2: Production (connected to real backend) ──
# Point these at the running backend servers.
# VITE_HOST=https://api.your-domain.com
# VITE_WS_HOST=wss://ws.your-domain.com

# ── Observability (optional) ──
# VITE_SENTRY_DSN=
# VITE_SENTRY_RELEASE=

# ── Feedback widget (optional, SurveyDesk) ──
# Base URL of the SurveyDesk service; the shared feedback widget renders only when this is set.
# VITE_SURVEYDESK_URL=

# ── DeskCloud widgets (optional) — each renders only when its *_URL is set ──
# ChangelogDesk: "What's new" launcher. PK is the publishable key (defaults to pk_demo).
# VITE_CHANGELOGDESK_URL=
# VITE_CHANGELOGDESK_PK=
# NotifyDesk: notification bell + inbox dropdown.
# VITE_NOTIFYDESK_URL=
# VITE_NOTIFYDESK_PK=
# SearchDesk: ⌘K command/search palette.
# VITE_SEARCHDESK_URL=
# VITE_SEARCHDESK_PK=
