# ──────────────────────────────────────────────────────────────────────
# Production environment variables for docker-compose.prod.yml
# Copy to .env.production and fill in the values.
# ──────────────────────────────────────────────────────────────────────

# ── Database ──
DB_USER=remote_devtools
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
DB_NAME=remote_devtools

# ── Auth (optional — leave blank for single-tenant self-host) ──
# Set to enable JWT-based auth. Generate with: openssl rand -hex 32
AUTH_JWT_SECRET=

# ── Admin API protection (recommended) ──
# Protects admin routes. Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# ── CORS (comma-separated apex domains) ──
# e.g., example.com,staging.example.com
CORS_ALLOWED_ORIGINS=

# ── Service URLs (auto-configured for docker-compose) ──
# Override only when services run on separate hosts.
# INTERNAL_HOST=https://internal.your-domain.com
# EXTERNAL_HOST=https://external.your-domain.com

# ── Ports ──
HTTP_PORT=80
HTTPS_PORT=443

# ── Jira integration (optional) ──
JIRA_HOST_URL=
JIRA_API_EMAIL=
JIRA_API_TOKEN=

# ── Slack integration (optional) ──
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ── Error monitoring (optional) ──
SENTRY_DSN=
