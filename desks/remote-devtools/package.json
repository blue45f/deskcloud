{
  "name": "@desk/remote-devtools",
  "version": "1.0.0",
  "description": "Remote debugging platform for web applications with recording and replay capabilities",
  "author": "",
  "private": true,
  "license": "MIT",
  "files": [
    "dist",
    "Dockerfile",
    "ecosystem.config.js",
    "assets",
    "devtools-frontend",
    "client/dist",
    "sdk/dist",
    ".dockerignore"
  ],
  "scripts": {
    "clean": "sh ./scripts/cleaner.sh",
    "typecheck": "tsc --noEmit && cd figma-plugin && npx tsc --noEmit",
    "build": "pnpm run build:all",
    "build:internal": "nest build remote-platform-internal",
    "build:external": "nest build remote-platform-external",
    "build:react": "pnpm --filter remote-debug-sdk build && pnpm --filter @desk/remote-devtools-client build && pnpm --filter @desk/remote-devtools-figma-plugin build",
    "build:all": "pnpm run build:internal && pnpm run build:external && pnpm run build:react",
    "start:container": "pm2-runtime start ecosystem.config.js",
    "start:internal": "nest start remote-platform-internal",
    "start:internal:dev": "nest start remote-platform-internal --watch",
    "start:external": "nest start remote-platform-external",
    "start:external:dev": "nest start remote-platform-external --watch",
    "compose": "docker-compose up",
    "migration:generate": "node --import 'data:text/javascript,import { register } from \"node:module\"; import { pathToFileURL } from \"node:url\"; register(\"ts-node/esm\", pathToFileURL(\"./\"))' --no-warnings ./node_modules/typeorm/cli.js migration:generate -d libs/core/src/datasource.ts",
    "migration:run": "ts-node ./node_modules/typeorm/cli.js migration:run -d libs/core/src/datasource.ts",
    "migration:revert": "ts-node ./node_modules/typeorm/cli.js migration:revert -d libs/core/src/datasource.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "prepare": "husky",
    "lint": "eslint apps/ libs/",
    "lint:fix": "eslint apps/ libs/ --fix",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "format:check": "prettier --check \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "ci": "pnpm run format:check && pnpm run lint:ci && pnpm run typecheck && pnpm run test && pnpm run build:all",
    "verify": "pnpm run validate:architecture && pnpm run ci",
    "verify:push": "pnpm run verify && pnpm run lint:security",
    "sonar": "sonar-scanner",
    "lint:strict": "eslint apps/ libs/ --max-warnings=0",
    "lint:ci": "pnpm run lint:strict",
    "audit:security": "pnpm audit --audit-level high --ignore GHSA-2p57-rm9w-gvfp",
    "lint:security": "pnpm run lint:strict && pnpm run audit:security",
    "sonar:ci": "sonar-scanner -Dsonar.qualitygate.wait=true",
    "validate": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build:all",
    "devtools:dev": "browser-sync start --proxy 'localhost:3000' --files 'devtools-frontend/**/*' --port 3002 --no-open --no-notify",
    "validate:architecture": "node scripts/validate-architecture.mjs",
    "turbo:build": "pnpm exec turbo run build",
    "turbo:typecheck": "pnpm exec turbo run typecheck",
    "turbo:lint": "pnpm exec turbo run lint",
    "turbo:test": "pnpm exec turbo run test --concurrency=1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-ws": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.24",
    "@sentry/nestjs": "^10.57.0",
    "@types/express": "^5.0.6",
    "axios": "^1.16.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "devtools-protocol": "^0.0.1646372",
    "dotenv": "^17.4.2",
    "escape-html": "^1.0.3",
    "express": "^5.2.1",
    "form-data": "^4.0.6",
    "google-auth-library": "^10.7.0",
    "googleapis": "^173.0.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.5.1",
    "mime": "^4.1.0",
    "nestjs-zod": "^5.4.0",
    "p-retry": "^8.0.0",
    "pg": "^8.21.0",
    "playwright": "^1.60.0",
    "pm2": "^7.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^22.2.0",
    "typeorm": "^1.0.0",
    "ua-parser-js": "^2.0.10",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@heejun/eslint-config": "^4.0.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.26",
    "@types/escape-html": "^1.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.9",
    "browser-sync": "^3.0.4",
    "embedded-postgres": "18.3.0-beta.17",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.4.0"
}
