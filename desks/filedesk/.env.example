# ──────────────────────────────────────────────────────────────────────────
# FileDesk — 환경 변수 예시. 복사: cp .env.example .env
# 모든 키는 선택값(미설정 시 apps/api/src/config.ts 기본값으로 폴백).
# ──────────────────────────────────────────────────────────────────────────

# 배포 모드: 'saas'(외부 온보딩, 멀티테넌트 가입) | 'self-hosted'(첫 부팅 시 데모 시드)
FILEDESK_MODE=self-hosted

# API 포트(FREE 하이포트). 기본 4100.
PORT=4100

# 대시보드(web) origin — CORS/링크 표기에 사용.
WEB_ORIGIN=http://localhost:5300

# 문의(/support) 게시판 백엔드(desk-platform) 베이스 URL. web 빌드 시 주입(VITE_*).
# 미설정 시 프로덕션 기본값(https://desk-platform.vercel.app)으로 폴백.
# 로컬 desk-platform api 검증: VITE_DESK_PLATFORM_URL=http://localhost:6090
# VITE_DESK_PLATFORM_URL=https://desk-platform.vercel.app

# 통합 회원 로그인(Firebase Auth) — web 빌드 시 주입(VITE_*). 미설정이면 회원 로그인은
# 친절히 비활성(빌드/런타임 크래시 없음). 리터럴 apiKey 커밋 금지(시크릿 스캔 차단).
# 로컬: cp ~/.config/deskcloud-firebase.env apps/web/.env.local (gitignored). Vercel: 프로젝트 env.
# projectId/authDomain 은 비밀 아닌 고정 식별자라 미설정 시 deskcloud-fleet-auth 로 폴백.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_SENDER_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_AUTH_DOMAIN=deskcloud-fleet-auth.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=deskcloud-fleet-auth

# 데이터베이스. 있으면 PostgreSQL(node-postgres), 비우면 PGlite 임베드 폴백.
# 로컬은 PGlite 또는 qa-postgres 를 쓰세요. neon.tech URL 금지.
# DATABASE_URL=postgres://user:pass@localhost:5432/filedesk
PGLITE_DIR=.data/pglite

# 플랫폼 운영자 마스터 토큰 — X-Admin-Token 헤더와 일치하면 어드민 경로 통과.
# 운영에서는 반드시 강한 무작위 값으로 교체하세요.
ADMIN_TOKEN=dev-admin-token-change-me

# secret 키 해시에 섞는 페퍼(앱 전역). 운영에서는 강한 무작위 값으로 교체.
DESK_KEY_PEPPER=dev-pepper-change-me

# free 플랜 누적 파일 수 소프트 캡. 기본 100.
FREE_PLAN_FILE_CAP=100

# 업로드 최대 바이트(어댑터 공통 안전 한도). 기본 5MB(5242880).
MAX_FILE_BYTES=5242880

# 스토리지 드라이버: 'postgres'(bytea, v1 기본) | 's3'(프로덕션 스왑, 실제 자격증명 필요).
DESK_STORAGE_DRIVER=postgres

# S3/R2 어댑터 설정(DESK_STORAGE_DRIVER=s3 일 때). 실제 자격증명은 커밋 금지 — 플레이스홀더만.
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=

# 시드 제어
# saas 모드에서 데모 시드를 켜려면 FILEDESK_SEED=true
# FILEDESK_SEED=true
# 데모 시드를 끄려면 FILEDESK_SEED_DEMO=false
# FILEDESK_SEED_DEMO=false
