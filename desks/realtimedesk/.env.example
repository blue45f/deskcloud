# ───────────────────────────────────────────────────────────────────────────
# RealtimeDesk — 환경 변수 예시. `cp .env.example .env` 후 값을 채우세요.
# (apps/api 가 읽습니다. 웹 대시보드용 VITE_* 변수는 Stage 2에서 추가.)
# ───────────────────────────────────────────────────────────────────────────

# 배포 모드: 'self-hosted'(사내 설치, demo 테넌트 시드) | 'saas'(멀티테넌트, 가입형)
REALTIMEDESK_MODE=self-hosted

# API/WS 서버 포트 (포트폴리오 내 다른 프로젝트와 겹치지 않도록 4092 사용)
PORT=4092

# 웹 대시보드 origin (CORS 허용 대상) — 어드민 REST 용. 공개 WS/pk 경로는 테넌트별 allowlist.
WEB_ORIGIN=http://localhost:5292

# socket.io 마운트 경로 — 게이트웨이 뒤에서도 정확 매칭되도록 명시(트레일링 슬래시 금지).
REALTIME_PATH=/realtime

# 채널당 보관할 최근 메시지 수(history). 0이면 영속화/히스토리 비활성.
REALTIME_HISTORY_LIMIT=50

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
# DATABASE_URL 이 있으면 PostgreSQL(node-postgres)을 사용합니다 (셀프호스트/SaaS 권장).
# 비어 있으면 PGlite 임베드 DB로 폴백 → Postgres·Docker 없이 `pnpm dev` 즉시 실행(개발/데모).
#   예) postgresql://realtimedesk:realtimedesk@localhost:5433/realtimedesk
# 주의: neon.tech 금지. 로컬은 PGlite(빈 값) 또는 qa-postgres(:5433) 만.
DATABASE_URL=

# PGlite 폴백 시 데이터 저장 디렉터리
PGLITE_DIR=.data/pglite

# ── 관리자(어드민) 인증 ──────────────────────────────────────────────────────
# 어드민 API(테넌트 단건 조회·키 회전·사용량)는 X-Admin-Token 헤더 또는 테넌트 sk 로 통과.
# 운영 시 반드시 강한 무작위 값으로 교체.
ADMIN_TOKEN=dev-admin-token-change-me

# ── 시드 ─────────────────────────────────────────────────────────────────────
# self-hosted 모드는 첫 부팅 시 데모 테넌트(pk_demo / sk_demo, corsOrigins ['*'])를 시드합니다.
# saas 모드에서 시드하려면 REALTIMEDESK_SEED=true.
# REALTIMEDESK_SEED=false

# ── 웹 대시보드 (apps/web · Vite, 빌드 타임 주입 — Stage 2에서 추가) ───────────
VITE_API_BASE_URL=http://localhost:4092
