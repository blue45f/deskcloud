{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2023",
    "lib": ["ES2023"],
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "declaration": false,
    "sourceMap": true,
    // NestJS DI/데코레이터는 타입의 런타임 import(emitDecoratorMetadata)에 의존하므로
    // verbatimModuleSyntax 는 반드시 꺼 둔다(켜면 type-only import 가 Nest DI 를 깨뜨림).
    // isolatedModules 도 CommonJS 데코레이터 방출 안정성을 위해 api 에서만 꺼 둔다.
    "isolatedModules": false,
    "verbatimModuleSyntax": false
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
