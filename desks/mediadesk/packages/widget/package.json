{
  "name": "@mediadesk/widget",
  "version": "0.1.0",
  "private": true,
  "description": "MediaDesk 임베드 미디어 위젯 — publishable 키로 동작하는 <MediaUploader>(드래그앤드롭·미리보기·진행률·에러·용량/MIME 가드)와 <MediaGallery>(반응형 변환 썸네일 그리드). React 컴포넌트 + 바닐라 IIFE 로더(window.MediaDesk). 의존성은 react(peer)와 @mediadesk/sdk 뿐, 외부 CSS 프레임워크 0.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vanilla": {
      "types": "./dist/vanilla.d.ts",
      "import": "./dist/vanilla.js",
      "require": "./dist/vanilla.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && vite build --config vite.iife.config.ts",
    "build:demo": "vite build --config demo/vite.config.ts",
    "dev": "tsup --watch",
    "dev:demo": "vite --config demo/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist demo/dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@mediadesk/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
