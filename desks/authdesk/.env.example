# ───────────────────────────────────────────────────────────────────────────
# AuthDesk — 환경 변수 예시. `cp .env.example .env` 후 값을 채우세요.
# (apps/api 가 읽습니다. 웹 대시보드용 VITE_* 변수는 맨 아래.)
# ───────────────────────────────────────────────────────────────────────────

# 배포 모드: 'self-hosted'(사내 설치, 시드 자동) | 'saas'(멀티테넌트, 가입형)
AUTHDESK_MODE=self-hosted

# API 서버 포트 (포트폴리오 내 다른 프로젝트와 겹치지 않도록 4110 사용)
PORT=4110

# 웹 대시보드 origin (CORS 허용 대상) — 공개 위젯 경로는 테넌트별 CORS allowlist 로 검사
WEB_ORIGIN=http://localhost:5310

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
# DATABASE_URL 이 있으면 PostgreSQL(node-postgres)을 사용합니다 (셀프호스트/SaaS 권장).
# 비어 있으면 PGlite 임베드 DB로 폴백 → Postgres·Docker 없이 `pnpm dev` 즉시 실행(개발/데모).
#   예) postgresql://authdesk:authdesk@localhost:5432/authdesk
DATABASE_URL=

# PGlite 폴백 시 데이터 저장 디렉터리
PGLITE_DIR=.data/pglite

# ── 키/토큰 시크릿 ───────────────────────────────────────────────────────────
# secret 키(sk_…)는 SHA-256(키 + pepper) 해시로만 저장합니다. pepper 는 서버 비밀.
# DB 가 유출돼도 pepper 없이는 키를 역산하기 어렵게 만드는 값 — 운영 시 강한 무작위로 교체.
AUTHDESK_KEY_PEPPER=dev-pepper-change-me

# end-user 세션 JWT 서명 비밀의 베이스. 테넌트별 비밀은 HMAC(base, tenantId)로 파생합니다.
# (각 테넌트 사용자 풀이 격리된 서명 도메인을 갖도록 — 한 테넌트 비밀이 새도 다른 테넌트는 안전.)
AUTHDESK_JWT_SECRET=dev-jwt-secret-change-me

# end-user 액세스 토큰 수명(초). 기본 1시간.
AUTHDESK_ACCESS_TTL=3600

# ── 관리자(어드민) 인증 ──────────────────────────────────────────────────────
# 어드민 API(테넌트 전역 사용자 목록·통계)는 X-Admin-Token 헤더가 이 값과 일치해야 통과.
# 운영 시 반드시 강한 무작위 값으로 교체.
ADMIN_TOKEN=dev-admin-token-change-me

# ── 시드 ─────────────────────────────────────────────────────────────────────
# self-hosted 모드는 첫 부팅 시 데모 테넌트(pk_demo…/sk_demo…)와 샘플 end-user 를 시드합니다.
# saas 모드에서 시드하려면 AUTHDESK_SEED=true.
# AUTHDESK_SEED=false

# ── 웹 대시보드 (apps/web · Vite, 빌드 타임 주입) ────────────────────────────
VITE_API_BASE_URL=http://localhost:4110
