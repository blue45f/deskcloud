{
  "name": "@aidigestdesk/content",
  "version": "0.1.0",
  "private": true,
  "description": "AIDigestDesk 콘텐츠 계약 — 한국어 AI/LLM 포털용 모델·업데이트·벤치마크·학습 리소스 데이터와 검색 유틸.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "verify:events": "node scripts/verify-events.mjs",
    "snapshot:sources": "pnpm run build && node scripts/snapshot-sources.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
