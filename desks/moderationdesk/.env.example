# ───────────────────────────────────────────────────────────────────────────
# ModerationDesk — 환경 변수 예시. `cp .env.example .env` 후 값을 채우세요.
# (apps/api 가 읽습니다. 웹 대시보드용 VITE_* 변수는 맨 아래.)
# ───────────────────────────────────────────────────────────────────────────

# 배포 모드: 'self-hosted'(사내 설치, 데모 시드 자동) | 'saas'(멀티테넌트, 가입형)
MODERATIONDESK_MODE=self-hosted

# API 서버 포트 (포트폴리오 내 다른 프로젝트와 겹치지 않도록 4092 사용)
PORT=4092

# 웹 대시보드 origin (CORS 허용 대상) — 공개 위젯 경로는 테넌트별 corsOrigins 로 별도 제어
WEB_ORIGIN=http://localhost:5292

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
# DATABASE_URL 이 있으면 PostgreSQL(node-postgres)을 사용합니다 (셀프호스트/SaaS 권장).
# 비어 있으면 PGlite 임베드 DB로 폴백 → Postgres·Docker 없이 `pnpm dev` 즉시 실행(개발/데모).
#   예) postgresql://moderationdesk:moderationdesk@localhost:5432/moderationdesk
#   로컬 qa-postgres 예) postgresql://qa:qa@localhost:5433/moderationdesk
DATABASE_URL=

# PGlite 폴백 시 데이터 저장 디렉터리
PGLITE_DIR=.data/pglite

# ── 관리자(셀프호스트 글로벌) 인증 ──────────────────────────────────────────
# 어드민 API(규칙·신고·로그·테넌트 설정)는 다음 중 하나로 통과합니다:
#   1) 테넌트별 SECRET 키 (X-Sk 헤더, sk_...) — SaaS 고객용
#   2) 글로벌 ADMIN_TOKEN (X-Admin-Token 헤더) — 셀프호스트 운영자용(모든 테넌트 접근)
# 운영 시 반드시 강한 무작위 값으로 교체.
ADMIN_TOKEN=dev-admin-token-change-me

# ── 모더레이션: AI 보조(선택) ────────────────────────────────────────────────
# 규칙 기반 검사(금칙어/정규식/부분일치)는 항상 동작합니다.
# ANTHROPIC_API_KEY 가 설정되어 있으면, 규칙 외에 Claude(haiku)로 독성/카테고리 점수를
# 추가로 산출합니다. 키가 없으면 AI 경로는 조용히 건너뛰고 규칙 기반만 사용합니다.
# (절대 하드페일하지 않습니다 — 키 없음/오류 시 규칙 결과로 안전 폴백.)
# ANTHROPIC_API_KEY=
# AI 보조에 사용할 모델 id (작고 저렴한 모델 권장). 기본: claude-haiku-4-5
# MODERATION_AI_MODEL=claude-haiku-4-5

# ── 시드 ─────────────────────────────────────────────────────────────────────
# self-hosted 모드는 첫 부팅 시 데모 테넌트(pk_demo/sk_demo)·금칙 규칙·샘플 신고/로그를 자동 시드합니다.
# saas 모드에서 시드하려면 MODERATIONDESK_SEED=true.
# MODERATIONDESK_SEED=false

# 데모 시드를 끄려면(self-hosted 운영 등) MODERATIONDESK_SEED_DEMO=false
# MODERATIONDESK_SEED_DEMO=false

# ── 무료 플랜 소프트 한도 ────────────────────────────────────────────────────
# 무료(free) 플랜 테넌트의 누적 모더레이션 검사 상한(초과 시 402). 0 또는 미설정 시 기본값.
# FREE_PLAN_LIMIT=1000

# ── 웹 대시보드 (apps/web · Vite, 빌드 타임 주입 — Stage 2에서 추가) ───────────
VITE_API_BASE_URL=http://localhost:4092
