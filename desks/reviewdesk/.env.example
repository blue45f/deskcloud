# ───────────────────────────────────────────────────────────────────────────
# ReviewDesk — 환경 변수 예시. `cp .env.example .env` 후 값을 채우세요.
# (apps/api 가 읽습니다. 웹 대시보드용 VITE_* 변수는 맨 아래.)
# ───────────────────────────────────────────────────────────────────────────

# 배포 모드: 'self-hosted'(사내 설치, 데모 시드 자동) | 'saas'(멀티테넌트, 가입형)
REVIEWDESK_MODE=self-hosted

# API 서버 포트 (포트폴리오 내 다른 프로젝트와 겹치지 않도록 4099 사용)
PORT=4099

# 웹 대시보드 origin (CORS 허용 대상) — 공개 위젯 경로는 테넌트별 corsOrigins 로 별도 제어
WEB_ORIGIN=http://localhost:5299

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
# DATABASE_URL 이 있으면 PostgreSQL(node-postgres)을 사용합니다 (셀프호스트/SaaS 권장).
# 비어 있으면 PGlite 임베드 DB로 폴백 → Postgres·Docker 없이 `pnpm dev` 즉시 실행(개발/데모).
#   예) postgresql://reviewdesk:reviewdesk@localhost:5432/reviewdesk
#   로컬 qa-postgres 예) postgresql://qa:qa@localhost:5433/reviewdesk
DATABASE_URL=

# PGlite 폴백 시 데이터 저장 디렉터리
PGLITE_DIR=.data/pglite

# ── 관리자(셀프호스트 글로벌) 인증 ──────────────────────────────────────────
# 어드민 API(검수·테넌트 설정)는 다음 중 하나로 통과합니다:
#   1) 테넌트별 SECRET 키 (X-Sk 헤더, sk_...) — SaaS 고객용
#   2) 글로벌 ADMIN_TOKEN (X-Admin-Token 헤더) — 셀프호스트 운영자용(모든 테넌트 접근)
# 운영 시 반드시 강한 무작위 값으로 교체.
ADMIN_TOKEN=dev-admin-token-change-me

# ── 시드 ─────────────────────────────────────────────────────────────────────
# self-hosted 모드는 첫 부팅 시 데모 테넌트(pk_demo/sk_demo)와 샘플 리뷰를 자동 시드합니다.
# saas 모드에서 시드하려면 REVIEWDESK_SEED=true.
# REVIEWDESK_SEED=false

# 데모 시드를 끄려면(self-hosted 운영 등) REVIEWDESK_SEED_DEMO=false
# REVIEWDESK_SEED_DEMO=false

# ── 무료 플랜 소프트 한도 ────────────────────────────────────────────────────
# 무료(free) 플랜 테넌트의 누적 리뷰 제출 상한(초과 시 402). 0 또는 미설정 시 기본값.
# FREE_PLAN_LIMIT=500

# ── 웹 대시보드 (apps/web · Vite, 빌드 타임 주입 — Stage 2에서 추가) ───────────
VITE_API_BASE_URL=http://localhost:4099
