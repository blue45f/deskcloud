{
  "name": "@addesk/web",
  "version": "0.1.0",
  "private": true,
  "description": "AdDesk 대시보드 — 셀프 가입(pk_/sk_)·어드민 로그인(sk_)·캠페인/크리에이티브/슬롯 관리·통계(CTR)·배너 위젯 데모·임베드 가이드·디자인 시스템(/design).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 5296",
    "typecheck": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@addesk/shared": "workspace:*",
    "@addesk/widget": "workspace:*",
    "firebase": "^12.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
