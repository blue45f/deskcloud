{
  "name": "@termsdesk/api",
  "version": "0.1.0",
  "private": true,
  "description": "TermsDesk API — NestJS + Drizzle. 버전드 약관 레지스트리, 변조 방지 게시, append-only 동의 영수증, 감사 로그.",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed.ts",
    "verify": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "@electric-sql/pglite": "^0.5.1",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.27",
    "@termsdesk/shared": "workspace:*",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.2.0",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.21.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
