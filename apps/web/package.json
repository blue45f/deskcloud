{
  "name": "@aidigestdesk/web",
  "version": "0.1.0",
  "private": true,
  "description": "AIDigestDesk 웹 포털 — 한국어 AI/LLM 업데이트, 벤치마크, 기능 비교, 사용법, 강좌/도서, 출처 큐레이션.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check:bundle": "node scripts/check-build-assets.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 5297",
    "typecheck": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aidigestdesk/content": "workspace:*",
    "@heejun/deskcloud": "^0.1.0",
    "firebase": "^12.15.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
