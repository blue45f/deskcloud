# AIDigestDesk — 환경 변수 예시
#
# DeskCloud 플랫폼(@heejun/deskcloud) 연동은 모두 선택(env-gated)입니다.
# 아래 변수를 설정하면 해당 기능이 실제 DeskCloud 서비스로 위임되고,
# 비워두면 브라우저 로컬 데모(회원/커뮤니티) 또는 내부 정적 문서(약관)로 폴백합니다.
#
# 전제: DeskCloud 백엔드(11개 Desk + 게이트웨이)가 도커 호스트에 배포되고,
# 테넌트 publishable(pk_) 키와 CORS allowlist(이 사이트 Origin 등록)가 준비되어야 합니다.
# 참고: deskcloud-deploy/docs/STATUS.md, DEPLOY.md.
#
# 정적 SPA이므로 publishable(pk_) 키만 사용합니다. secret(sk_) 키는 절대 넣지 마세요.

# 회원 인증 → AuthDesk (회원가입/로그인/로그아웃)
# VITE_AUTHDESK_URL=https://<host>/auth
# VITE_AUTHDESK_PK=pk_live_xxx

# 커뮤니티 게시판·카페 → CommunityDesk (채팅방은 별도 realtime 서비스라 로컬 유지)
# VITE_COMMUNITYDESK_URL=https://<host>/community
# VITE_COMMUNITYDESK_PK=pk_live_xxx

# 약관·개인정보 게시본 → TermsDesk
# VITE_TERMSDESK_URL=https://<host>/terms
# VITE_TERMSDESK_PK=pk_live_xxx
# VITE_TERMSDESK_ORG=aidigestdesk

# (선택) Vite base path — 기본 '/'
# VITE_BASE_PATH=/
