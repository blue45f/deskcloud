# ───────────────────────────────────────────────────────────────────────────
# TermsDesk — 환경 변수 예시. `cp .env.example .env` 후 값을 채우세요.
# (apps/api 가 읽습니다. 웹 대시보드용 VITE_* 변수는 맨 아래.)
# ───────────────────────────────────────────────────────────────────────────

# 배포 모드: 'self-hosted'(사내 설치, 싱글테넌트) | 'saas'(멀티테넌트, 가입형)
TERMSDESK_MODE=self-hosted

# API 서버 포트 (포트폴리오 내 다른 프로젝트와 겹치지 않도록 4070 사용)
PORT=4070

# 웹 대시보드 origin (CORS 허용 대상)
WEB_ORIGIN=http://localhost:5270

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
# DATABASE_URL 이 있으면 PostgreSQL(node-postgres)을 사용합니다 (셀프호스트/SaaS 권장).
# 비어 있으면 PGlite 임베드 DB로 폴백 → Postgres·Docker 없이 `pnpm dev` 즉시 실행(개발/데모).
#   예) postgresql://termsdesk:termsdesk@localhost:5432/termsdesk
DATABASE_URL=

# PGlite 폴백 시 데이터 저장 디렉터리
PGLITE_DIR=.data/pglite

# ── 인증 ────────────────────────────────────────────────────────────────────
# 세션 JWT 서명 키. self-hosted 운영 시 반드시 강한 무작위 값으로 교체.
JWT_SECRET=dev-only-change-me-please

# 세션 쿠키 secure 플래그 — TLS(https) 종단 뒤에서만 true. http self-host는 false.
COOKIE_SECURE=false

# 첫 부팅 시 시드되는 관리자 계정 (self-hosted 최초 로그인용)
SEED_ADMIN_EMAIL=admin@termsdesk.local
SEED_ADMIN_PASSWORD=termsdesk-admin

# ── 게시(서빙) ───────────────────────────────────────────────────────────────
# 공개 정책 조회 API 응답의 CDN/Cache-Control TTL(초)
PUBLIC_CACHE_TTL=60

# ── 웹 대시보드 (apps/web · Vite, 빌드 타임 주입) ─────────────────────────────
VITE_API_BASE_URL=http://localhost:4070

# ── DeskCloud 네이티브 통합 (apps/web) ───────────────────────────────────────
# @heejun/deskcloud 의 타입드 브라우저 클라이언트(publishable `pk_` 키)로 연동하고,
# TermsDesk 자체 컴포넌트·디자인 토큰으로 네이티브 렌더합니다(위젯 임베드/외부 CSS X).
# 각 통합은 대응하는 *_URL 이 설정된 경우에만 활성화되며, 미설정 시 비활성(영향 없음).
# secret 키(`sk_…`)는 브라우저에 절대 넣지 마세요 — 서버 전용('@heejun/deskcloud/server').

# ChangelogDesk '변경 이력' 네이티브 패널(플로팅 런처 + 미확인 배지). PK 미지정 시 pk_demo.
#   예) VITE_CHANGELOGDESK_URL=https://changelogdesk.fly.dev
#       VITE_CHANGELOGDESK_PK=pk_live_xxxxxxxxxxxxxxxx
VITE_CHANGELOGDESK_URL=
VITE_CHANGELOGDESK_PK=

# NotifyDesk 네이티브 알림 인박스(헤더 벨 + 드롭다운). PK 미지정 시 pk_demo.
#   예) VITE_NOTIFYDESK_URL=https://notifydesk.fly.dev
#       VITE_NOTIFYDESK_PK=pk_live_xxxxxxxxxxxxxxxx
VITE_NOTIFYDESK_URL=
VITE_NOTIFYDESK_PK=
