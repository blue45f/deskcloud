# ───────────────────────────────────────────────────────────────────────────
# MediaDesk — 환경 변수 예시. `cp .env.example .env` 후 값을 채우세요.
# (apps/api 가 읽습니다. 웹 대시보드용 VITE_* 변수는 맨 아래.)
# ───────────────────────────────────────────────────────────────────────────

# 배포 모드: 'self-hosted'(사내 설치, 데모 테넌트 자동 시드) | 'saas'(멀티테넌트, 가입형)
MEDIADESK_MODE=self-hosted

# API 서버 포트 (포트폴리오 내 다른 프로젝트와 겹치지 않도록 4191 사용)
PORT=4191

# 웹 대시보드 origin (CORS 허용 대상). 공개(publishable) 엔드포인트는 테넌트별
# CORS 허용목록으로 별도 통제됩니다.
WEB_ORIGIN=http://localhost:5291

# 자산 공개 URL의 베이스. 비어 있으면 요청 host 로부터 추론합니다.
#   예) https://cdn.mediadesk.example
PUBLIC_BASE_URL=

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
# DATABASE_URL 이 있으면 PostgreSQL(node-postgres)을 사용합니다 (셀프호스트/SaaS 권장).
# 비어 있으면 PGlite 임베드 DB로 폴백 → Postgres·Docker 없이 `pnpm dev` 즉시 실행(개발/데모).
#   예) postgresql://mediadesk:mediadesk@localhost:5433/mediadesk
DATABASE_URL=

# PGlite 폴백 시 데이터 저장 디렉터리
PGLITE_DIR=.data/pglite

# ── 스토리지 ────────────────────────────────────────────────────────────────
# 스토리지 어댑터: 'local'(파일시스템, 기본) | 's3'(스텁 — 인터페이스만, 실제 AWS 미사용)
STORAGE_DRIVER=local

# local 어댑터의 루트(.gitignore 됨). 테넌트별 하위 디렉터리로 격리됩니다.
STORAGE_LOCAL_DIR=.data/uploads

# 파생(변환) 캐시 디렉터리 — sharp 변환 결과를 디스크에 캐시.
DERIVATIVE_CACHE_DIR=.data/derivatives

# s3 드라이버용(스텁) — 값이 있어도 실제 호출은 일어나지 않습니다.
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT=
# S3_PUBLIC_BASE_URL=

# ── 업로드 한도 ──────────────────────────────────────────────────────────────
# 단일 업로드 최대 바이트(기본 10MB). 본문 파서 한도와 함께 사용.
MAX_UPLOAD_BYTES=10485760
# free 플랜의 소프트 캡 — 누적 바이트·건수 초과 시 업로드 거부(402).
FREE_PLAN_MAX_BYTES=104857600
FREE_PLAN_MAX_COUNT=500

# ── 관리자(어드민) 인증 ──────────────────────────────────────────────────────
# 어드민 API 는 테넌트 secret 키(sk_) 또는 이 마스터 토큰(X-Admin-Token)으로 통과.
# 운영 시 반드시 강한 무작위 값으로 교체.
ADMIN_TOKEN=dev-admin-token-change-me

# ── 시드 ─────────────────────────────────────────────────────────────────────
# self-hosted 모드는 첫 부팅 시 데모 테넌트(pk_demo/sk_demo)와 샘플 자산을 자동 시드합니다.
# saas 모드에서 시드하려면 MEDIADESK_SEED=true.
# MEDIADESK_SEED=false

# ── 웹 대시보드 (apps/web · Vite, 빌드 타임 주입 — Stage 2에서 추가) ───────────
VITE_API_BASE_URL=http://localhost:4191

# ── 통합 로그인 (Firebase Auth · 이메일/비번 + 게스트) ─────────────────────────
# 공개 식별자지만 시크릿 스캔 훅이 AIza… 패턴을 차단하므로 실제 값은 커밋하지 말고
# apps/web/.env.local(gitignored) + Vercel 프로젝트 env 로만 주입한다.
# authDomain/projectId 는 미설정 시 'deskcloud-fleet-auth' 기본값을 쓴다.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_AUTH_DOMAIN=deskcloud-fleet-auth.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=deskcloud-fleet-auth
