# ───────────────────────────────────────────────────────────────────────────
# SurveyDesk — 환경 변수 예시. `cp .env.example .env` 후 값을 채우세요.
# (apps/api 가 읽습니다. 웹 대시보드용 VITE_* 변수는 맨 아래.)
# ───────────────────────────────────────────────────────────────────────────

# 배포 모드: 'self-hosted'(사내 설치, 시드 자동) | 'saas'(멀티테넌트, 가입형)
SURVEYDESK_MODE=self-hosted

# API 서버 포트 (포트폴리오 내 다른 프로젝트와 겹치지 않도록 4090 사용)
PORT=4090

# 웹 대시보드 origin (CORS 허용 대상) — 공개 위젯 경로는 항상 CORS 개방
WEB_ORIGIN=http://localhost:5290

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
# DATABASE_URL 이 있으면 PostgreSQL(node-postgres)을 사용합니다 (셀프호스트/SaaS 권장).
# 비어 있으면 PGlite 임베드 DB로 폴백 → Postgres·Docker 없이 `pnpm dev` 즉시 실행(개발/데모).
#   예) postgresql://surveydesk:surveydesk@localhost:5432/surveydesk
DATABASE_URL=

# PGlite 폴백 시 데이터 저장 디렉터리
PGLITE_DIR=.data/pglite

# ── 관리자(어드민) 인증 ──────────────────────────────────────────────────────
# 어드민 API(응답 목록·집계·설문 CRUD)는 X-Admin-Token 헤더가 이 값과 일치해야 통과.
# 운영 시 반드시 강한 무작위 값으로 교체.
ADMIN_TOKEN=dev-admin-token-change-me

# ── 시드 ─────────────────────────────────────────────────────────────────────
# self-hosted 모드는 첫 부팅 시 데모 설문(demo·offhours)과 샘플 응답을 자동 시드합니다.
# saas 모드에서 시드하려면 SURVEYDESK_SEED=true.
# SURVEYDESK_SEED=false

# ── 웹 대시보드 (apps/web · Vite, 빌드 타임 주입 — Stage 2에서 추가) ───────────
VITE_API_BASE_URL=http://localhost:4090

# 문의(Inquiry) 게시판 — desk-platform 공개 API 베이스 URL.
# 없으면 prod 기본값(https://desk-platform.vercel.app)을 사용합니다. 로컬 검증은 :6090.
# VITE_DESK_PLATFORM_URL=http://localhost:6090
