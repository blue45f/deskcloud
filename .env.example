# ───────────────────────────────────────────────────────────────────────────
# NotifyDesk — 환경 변수 예시. `cp .env.example .env` 후 값을 채우세요.
# (apps/api 가 읽습니다. 웹 대시보드용 VITE_* 변수는 맨 아래.)
# ───────────────────────────────────────────────────────────────────────────

# 배포 모드: 'saas'(외부 온보딩형, 멀티테넌트 가입) | 'self-hosted'(사내 설치, 시드 자동)
# NotifyDesk 는 외부 온보딩형이라 기본 saas. self-hosted 면 첫 부팅 시 데모 시드.
NOTIFYDESK_MODE=saas

# API 서버 포트 (포트폴리오 내 다른 프로젝트와 겹치지 않도록 4095 사용)
PORT=4095

# 웹 대시보드 origin (CORS 허용 대상) — 공개(publishable) 경로는 테넌트별 CORS 허용목록을 따름
WEB_ORIGIN=http://localhost:5295

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
# DATABASE_URL 이 있으면 PostgreSQL(node-postgres)을 사용합니다 (셀프호스트/SaaS 권장).
# 비어 있으면 PGlite 임베드 DB로 폴백 → Postgres·Docker 없이 `pnpm dev` 즉시 실행(개발/데모).
#   예) postgresql://notifydesk:notifydesk@localhost:5433/notifydesk   (qa-postgres)
DATABASE_URL=

# PGlite 폴백 시 데이터 저장 디렉터리
PGLITE_DIR=.data/pglite

# ── 관리자(어드민) 인증 ──────────────────────────────────────────────────────
# 테넌트 secret 키(sk_) 외에, 플랫폼 운영자용 마스터 토큰.
# 어드민/발송 경로는 sk_ 키 또는 이 ADMIN_TOKEN 헤더(X-Admin-Token)로 통과.
# 운영 시 반드시 강한 무작위 값으로 교체.
ADMIN_TOKEN=dev-admin-token-change-me

# ── 무료 플랜 소프트 캡 ───────────────────────────────────────────────────────
# 테넌트별 누적 발송 건수가 이 값을 넘으면 free 플랜은 발송이 거부됩니다(소프트 캡).
# pro 플랜 테넌트는 캡 무제한.
FREE_PLAN_CAP=1000

# ── 이메일 채널(선택) ─────────────────────────────────────────────────────────
# 미설정이면 콘솔 로그 어댑터로 폴백(이메일을 stdout 에 출력). nodemailer/SMTP 는 선택.
# SMTP_URL 이 있으면 nodemailer SMTP 어댑터를 사용합니다.
#   예) smtp://user:pass@smtp.example.com:587
SMTP_URL=
EMAIL_FROM=NotifyDesk <no-reply@notifydesk.local>

# ── 웹 푸시(선택, VAPID) ──────────────────────────────────────────────────────
# 둘 다 설정되어야 web-push 가 동작합니다. 미설정이면 web-push 채널은 no-op.
#   pnpm dlx web-push generate-vapid-keys  로 키쌍 생성
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@notifydesk.local

# ── 시드 ─────────────────────────────────────────────────────────────────────
# self-hosted 모드는 첫 부팅 시 데모 테넌트(pk_demo/sk_demo)·템플릿·인박스 알림을 시드.
# saas 모드에서도 데모를 시드하려면 NOTIFYDESK_SEED=true.
NOTIFYDESK_SEED=true

# ── 웹 대시보드 (apps/web · Vite, 빌드 타임 주입 — Stage 2에서 추가) ───────────
VITE_API_BASE_URL=http://localhost:4095

# 문의(/support) 게시판 백엔드 — desk-platform 공개 API 베이스 URL.
# 미설정이면 프로덕션(https://desk-platform.vercel.app) 기본값. 로컬 검증은 :6090.
VITE_DESK_PLATFORM_URL=https://desk-platform.vercel.app

# ── 통합 회원 로그인 (Firebase Auth · 선택) ──────────────────────────────────
# 형제 앱 공통 Firebase 프로젝트(deskcloud-fleet-auth)로 이메일/비번 + 게스트(익명) 로그인.
# apiKey 등 웹 config 는 공개 식별자지만 시크릿 스캔 훅이 AIza… 패턴을 차단하므로
# 소스에 박지 말고 .env.local(gitignored) + Vercel 프로젝트 env 로 주입한다.
# 미설정이면 런타임에서 친절히 degrade(빌드/타입체크는 그대로 통과).
# projectId/authDomain 은 비밀이 아니라 코드에 안전한 기본값이 있다(여기선 생략 가능).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=deskcloud-fleet-auth.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=deskcloud-fleet-auth
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=
