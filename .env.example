# ───────────────────────────────────────────────────────────────────────────
# @desk/platform — 환경 변수 예시. `cp .env.example .env` 후 값을 채우세요.
# (apps/api 가 읽습니다. 웹 대시보드용 VITE_* 변수는 맨 아래.)
# ───────────────────────────────────────────────────────────────────────────

# 배포 모드: 'self-hosted'(사내 설치, 데모 테넌트 자동 시드) | 'saas'(멀티테넌트, 가입형)
DESK_PLATFORM_MODE=self-hosted

# API 서버 포트 — 포트폴리오 내 다른 프로젝트와 겹치지 않도록 6090 사용.
# (피하기: 3000-3001,4001,4070,4090,5173-5174,5270,5432,8080,9000)
PORT=6090

# 웹 대시보드 origin (CORS 허용 대상) — 공개 publishable-key 경로는 별도 allowlist 사용
WEB_ORIGIN=http://localhost:6091

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
# DATABASE_URL 이 있으면 PostgreSQL(node-postgres)을 사용합니다 (셀프호스트/SaaS 권장).
# 비어 있으면 PGlite 임베드 DB로 폴백 → Postgres·Docker 없이 `pnpm dev` 즉시 실행(개발/데모).
#   로컬 qa-postgres 예) postgresql://postgres:postgres@localhost:5433/deskplatform
#   (neon.tech 금지. 로컬은 PGlite 또는 qa-postgres:5433 의 deskplatform DB만.)
DATABASE_URL=

# PGlite 폴백 시 데이터 저장 디렉터리
PGLITE_DIR=.data/pglite

# ── 관리자(어드민) 인증 ──────────────────────────────────────────────────────
# 어드민 API(테넌트 관리·플랜 변경)는 X-Admin-Token 헤더가 이 값과 일치해야 통과.
# 운영 시 반드시 강한 무작위 값으로 교체.
ADMIN_TOKEN=dev-admin-token-change-me

# 테넌트 시크릿 키 해시에 쓰이는 페퍼(서버 비밀). 운영 시 강한 무작위 값으로 교체.
# 비어 있으면 빈 페퍼로 동작(개발 전용).
DESK_KEY_PEPPER=dev-key-pepper-change-me

# ── 시드 ─────────────────────────────────────────────────────────────────────
# self-hosted 모드는 첫 부팅 시 데모 테넌트(Free 1 + Pro 1)를 멱등 시드합니다.
# saas 모드에서 시드하려면 DESK_PLATFORM_SEED=true.
# DESK_PLATFORM_SEED=false

# ── 빌링 어댑터 (TEST/STUB 전용 — 실제 결제 절대 안 함) ───────────────────────
# 어댑터 모드: 'stub'(기본, 인메모리 가짜 결제) | 'toss' | 'stripe'(현재 스텁 위임).
# 실제 Toss/Stripe 시크릿 키를 절대 넣지 마세요. 플레이스홀더만 허용.
DESK_BILLING_PROVIDER=stub
# 스텁/테스트 어댑터용 플레이스홀더 키 (실키 금지)
DESK_BILLING_TEST_KEY=test_placeholder_no_real_charges

# ── 웹 대시보드 (apps/web · Vite, 빌드 타임 주입 — Stage 2에서 추가) ───────────
VITE_API_BASE_URL=http://localhost:6090
