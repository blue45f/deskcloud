# ───────────────────────────────────────────────────────────────────────────
# CommunityDesk — 환경 변수 예시. `cp .env.example .env` 후 값을 채우세요.
# (apps/api 가 읽습니다. 웹 대시보드용 VITE_* 변수는 맨 아래.)
# ───────────────────────────────────────────────────────────────────────────

# 배포 모드: 'self-hosted'(사내 설치, 데모 시드 자동) | 'saas'(멀티테넌트, 가입형)
COMMUNITYDESK_MODE=self-hosted

# API 서버 포트 (포트폴리오 내 다른 프로젝트와 겹치지 않도록 4096 사용)
PORT=4096

# 웹 대시보드 origin (전역 CORS) — 공개 위젯 경로는 테넌트별 corsOrigins 로 별도 제어
WEB_ORIGIN=http://localhost:5296

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
# DATABASE_URL 이 있으면 PostgreSQL(node-postgres)을 사용합니다 (셀프호스트/SaaS 권장).
# 비어 있으면 PGlite 임베드 DB로 폴백 → Postgres·Docker 없이 `pnpm dev` 즉시 실행(개발/데모).
#   예) postgresql://communitydesk:communitydesk@localhost:5433/communitydesk
DATABASE_URL=

# PGlite 폴백 시 데이터 저장 디렉터리
PGLITE_DIR=.data/pglite

# ── 관리자(어드민) 인증 ──────────────────────────────────────────────────────
# 어드민 API 는 테넌트 secret 키(x-sk) 또는 글로벌 X-Admin-Token 헤더로 인증합니다.
# X-Admin-Token 은 셀프호스트 운영자(모든 테넌트 접근)용 — 반드시 강한 무작위 값으로 교체.
ADMIN_TOKEN=dev-admin-token-change-me

# ── 무료 플랜 소프트 한도 ─────────────────────────────────────────────────────
# 테넌트 free 플랜의 누적 글 작성 소프트 한도. 초과 시 글 작성 402. (기본 1000)
# FREE_PLAN_LIMIT=1000

# ── 시드 ─────────────────────────────────────────────────────────────────────
# self-hosted 모드는 첫 부팅 시 데모 테넌트(pk_demo/sk_demo)와 게시판·카페·글·댓글·반응을
# 자동 시드합니다. saas 모드에서 시드하려면 COMMUNITYDESK_SEED=true.
# 데모 시드만 끄려면 COMMUNITYDESK_SEED_DEMO=false.
# COMMUNITYDESK_SEED=false

# ── 웹 대시보드 (apps/web · Vite, 빌드 타임 주입 — Stage 2에서 추가) ───────────
VITE_API_BASE_URL=http://localhost:4096

# 문의(/support) 게시판이 호출하는 desk-platform 공개 API 베이스 URL.
# 비우면 프로덕션(https://desk-platform.vercel.app) 기본값을 사용한다. 로컬 검증 시 http://localhost:6090.
# VITE_DESK_PLATFORM_URL=https://desk-platform.vercel.app

# ── 통합 회원 로그인 (Firebase Auth · apps/web) ───────────────────────────────
# 형제 앱 공유 Firebase 프로젝트(deskcloud-fleet-auth)로 이메일/비밀번호 + 게스트(익명)
# 회원 로그인을 제공합니다. 웹 apiKey 는 공개 식별자지만(보안은 Auth 규칙 + authorizedDomains)
# 시크릿 스캔 훅이 AIza… 패턴을 차단하므로 리터럴 커밋 금지 — 아래 값은 .env.local(gitignored)
# 또는 Vercel 프로젝트 env 로만 주입합니다. 실제 값은 ~/.config/deskcloud-firebase.env 에 비커밋 보관.
# 미설정이어도 빌드/번들은 정상이며, 런타임 인증 시도 시에만 친절히 안내합니다.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_SENDER_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# authDomain/projectId 는 비밀이 아니므로 기본값(deskcloud-fleet-auth)을 쓰며, 필요 시 오버라이드:
# VITE_FIREBASE_AUTH_DOMAIN=deskcloud-fleet-auth.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=deskcloud-fleet-auth
