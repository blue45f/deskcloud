# ───────────────────────────────────────────────────────────────────────────
# ChangelogDesk — 환경 변수 예시. `cp .env.example .env` 후 값을 채우세요.
# (apps/api 가 읽습니다. 웹 대시보드용 VITE_* 변수는 맨 아래.)
# ───────────────────────────────────────────────────────────────────────────

# 배포 모드: 'self-hosted'(사내 설치, 데모 테넌트 자동 시드) | 'saas'(멀티테넌트, 가입형)
CHANGELOGDESK_MODE=self-hosted

# API 서버 포트 (포트폴리오 내 다른 프로젝트와 겹치지 않도록 4095 사용)
PORT=4095

# 웹 대시보드 origin (CORS 허용 대상) — 공개 위젯 경로는 테넌트별 corsOrigins 로 제어
WEB_ORIGIN=http://localhost:5295

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
# DATABASE_URL 이 있으면 PostgreSQL(node-postgres)을 사용합니다 (셀프호스트/SaaS 권장).
# 비어 있으면 PGlite 임베드 DB로 폴백 → Postgres·Docker 없이 `pnpm dev` 즉시 실행(개발/데모).
#   예) postgresql://changelogdesk:changelogdesk@localhost:5432/changelogdesk
#   로컬 qa-postgres) postgresql://qa:qa@localhost:5433/changelogdesk
DATABASE_URL=

# PGlite 폴백 시 데이터 저장 디렉터리
PGLITE_DIR=.data/pglite

# ── 관리자(셀프호스트) 인증 ───────────────────────────────────────────────────
# 어드민 API 는 테넌트 시크릿 키(x-sk) 또는 이 글로벌 ADMIN_TOKEN(X-Admin-Token) 으로 통과.
# 셀프호스트 단일 테넌트 운영 시 글로벌 토큰이 편리합니다. 운영 시 강한 무작위 값으로 교체.
ADMIN_TOKEN=dev-admin-token-change-me

# ── 플랜 한도 ────────────────────────────────────────────────────────────────
# free 플랜 테넌트의 월간 공개 위젯 호출 소프트 한도(초과해도 차단하지 않고 경고/노출만).
FREE_PLAN_MONTHLY_LIMIT=10000

# ── 시드 ─────────────────────────────────────────────────────────────────────
# self-hosted 모드는 첫 부팅 시 데모 테넌트(pk_demo / sk_demo)와 샘플 체인지로그를 시드합니다.
# saas 모드에서 시드하려면 CHANGELOGDESK_SEED=true.
# CHANGELOGDESK_SEED=false

# ── 웹 대시보드 (apps/web · Vite, 빌드 타임 주입 — Stage 2에서 추가) ───────────
VITE_API_BASE_URL=http://localhost:4095
# /support 문의 게시판 백엔드(desk-platform 공개 API). 없으면 prod 기본값 사용.
# VITE_DESK_PLATFORM_URL=https://desk-platform.vercel.app

# ── 통합 회원 로그인 (Firebase Auth · deskcloud-fleet-auth) ───────────────────
# 이메일/비밀번호 + 게스트(익명) 로그인. apiKey 는 공개 식별자지만 시크릿 스캔 훅이
# AIza… 패턴을 차단하므로 리터럴 커밋 금지 — 로컬 .env.local(gitignored) + Vercel env 로 주입.
# 실제 값은 ~/.config/deskcloud-firebase.env 에 보관(비커밋):
#   cp ~/.config/deskcloud-firebase.env apps/web/.env.local
# 미설정이면 빌드는 정상이고 런타임에서만 친절히 degrade(isFirebaseAuthConfigured).
# authDomain/projectId 는 deskcloud-fleet-auth 기본값이라 생략 가능.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_SENDER_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_AUTH_DOMAIN=deskcloud-fleet-auth.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=deskcloud-fleet-auth
