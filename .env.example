# ───────────────────────────────────────────────────────────────────────────
# SearchDesk — 환경 변수 예시. `cp .env.example .env` 후 값을 채우세요.
# (apps/api 가 읽습니다. 웹 대시보드용 VITE_* 변수는 맨 아래.)
# ───────────────────────────────────────────────────────────────────────────

# 배포 모드: 'saas'(외부 온보딩형, 멀티테넌트 가입) | 'self-hosted'(사내 설치, 시드 자동)
# SearchDesk 는 외부 온보딩형이라 기본 saas. self-hosted 면 첫 부팅 시 데모 시드.
SEARCHDESK_MODE=saas

# API 서버 포트 (포트폴리오 내 다른 프로젝트와 겹치지 않도록 4093 사용)
PORT=4093

# 웹 대시보드 origin (CORS 허용 대상) — 공개(publishable) 경로는 테넌트별 CORS 허용목록을 따름
WEB_ORIGIN=http://localhost:5293

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
# DATABASE_URL 이 있으면 PostgreSQL(node-postgres)을 사용합니다 (셀프호스트/SaaS 권장).
#   → Postgres 경로에서는 tsvector(GIN) 전문 검색을 사용합니다.
# 비어 있으면 PGlite 임베드 DB로 폴백 → Postgres·Docker 없이 `pnpm dev` 즉시 실행(개발/데모).
#   → PGlite 경로에서는 이식성 있는 LIKE/소문자 토큰 랭킹 폴백을 사용합니다(동일 결과 형태).
#   예) postgresql://searchdesk:searchdesk@localhost:5433/searchdesk   (qa-postgres)
DATABASE_URL=

# PGlite 폴백 시 데이터 저장 디렉터리
PGLITE_DIR=.data/pglite

# ── 관리자(어드민) 인증 ──────────────────────────────────────────────────────
# 테넌트 secret 키(sk_) 외에, 플랫폼 운영자용 마스터 토큰.
# 색인/어드민 경로는 sk_ 키 또는 이 ADMIN_TOKEN 헤더(X-Admin-Token)로 통과.
# 운영 시 반드시 강한 무작위 값으로 교체.
ADMIN_TOKEN=dev-admin-token-change-me

# ── 무료 플랜 소프트 캡 ───────────────────────────────────────────────────────
# 테넌트별 누적 문서 수가 이 값을 넘으면 free 플랜은 추가 색인이 거부됩니다(소프트 캡).
# pro 플랜 테넌트는 캡 무제한.
FREE_PLAN_DOC_CAP=1000

# ── 검색 ─────────────────────────────────────────────────────────────────────
# 검색 결과 기본/최대 limit.
SEARCH_DEFAULT_LIMIT=10
SEARCH_MAX_LIMIT=50

# ── 시드 ─────────────────────────────────────────────────────────────────────
# self-hosted 모드는 첫 부팅 시 데모 테넌트(pk_demo/sk_demo)·샘플 문서(~20건)를 시드.
# saas 모드에서도 데모를 시드하려면 SEARCHDESK_SEED=true.
SEARCHDESK_SEED=true

# ── 웹 대시보드 (apps/web · Vite, 빌드 타임 주입 — Stage 2에서 추가) ───────────
VITE_API_BASE_URL=http://localhost:4093
# 문의(Inquiry) 게시판 백엔드(desk-platform). 없으면 prod 기본값(https://desk-platform.vercel.app).
# 로컬에서 desk-platform api 를 띄웠다면 http://localhost:6090 으로 지정.
VITE_DESK_PLATFORM_URL=https://desk-platform.vercel.app
