# ───────────────────────────────────────────────────────────────────────────
# AdDesk — 환경 변수 예시. `cp .env.example .env` 후 값을 채우세요.
# (apps/api 가 읽습니다. 웹 대시보드용 VITE_* 변수는 맨 아래.)
# ───────────────────────────────────────────────────────────────────────────

# 배포 모드: 'self-hosted'(사내 설치, 데모 테넌트 자동 시드) | 'saas'(멀티테넌트, 가입형)
ADDESK_MODE=self-hosted

# API 서버 포트 (포트폴리오 내 다른 프로젝트와 겹치지 않도록 4096 사용)
PORT=4096

# 웹 대시보드 origin (CORS 허용 대상) — 공개 위젯/서빙 경로는 테넌트별 corsOrigins 로 별도 제어
WEB_ORIGIN=http://localhost:5296

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
# DATABASE_URL 이 있으면 PostgreSQL(node-postgres)을 사용합니다 (셀프호스트/SaaS 권장).
# 비어 있으면 PGlite 임베드 DB로 폴백 → Postgres·Docker 없이 `pnpm dev` 즉시 실행(개발/데모).
#   예) postgresql://addesk:addesk@localhost:5432/addesk
DATABASE_URL=

# PGlite 폴백 시 데이터 저장 디렉터리
PGLITE_DIR=.data/pglite

# ── 관리자(어드민) 인증 ──────────────────────────────────────────────────────
# 글로벌 어드민 토큰 — X-Admin-Token 헤더가 이 값과 일치하면 모든 테넌트 어드민 접근(셀프호스트).
# 운영 시 반드시 강한 무작위 값으로 교체.
ADMIN_TOKEN=dev-admin-token-change-me

# secret 키 해시 페퍼 — 가입/검증 시 secret 키 해시에 섞는 서버 비밀값(키 자체 노출 시에도
# DB 해시만으로 역산을 어렵게 한다). 운영 시 강한 무작위 값으로 교체.
KEY_PEPPER=dev-pepper-change-me

# ── 사용량(무료 플랜 소프트 한도) ────────────────────────────────────────────
# 무료 플랜의 누적 광고 서빙(ad_serves) 소프트 한도. 초과 시 서빙 402.
# FREE_PLAN_LIMIT=50000

# ── 시드 ─────────────────────────────────────────────────────────────────────
# self-hosted 모드는 첫 부팅 시 데모 테넌트(pk_demo…/sk_demo…, 랜덤·로그 출력)와
# 샘플 캠페인·크리에이티브·슬롯을 자동 시드합니다.
# saas 모드에서 시드하려면 ADDESK_SEED=true. 데모 시드를 끄려면 ADDESK_SEED_DEMO=false.
# ADDESK_SEED=false

# ── 웹 대시보드 (apps/web · Vite, 빌드 타임 주입) ───────────────────────────
VITE_API_BASE_URL=http://localhost:4096

# ── 통합 로그인(Firebase Auth · 회원 로그인) ─────────────────────────────────
# 형제 앱 공용 Firebase 프로젝트(deskcloud-fleet-auth)로 이메일/비밀번호 + 게스트(익명)
# 로그인을 제공합니다. apiKey 등은 공개 식별자지만 시크릿 스캔 훅이 AIza… 패턴을 막으므로
# 리터럴을 커밋하지 않고 env 로만 주입합니다(로컬 apps/web/.env.local + Vercel 프로젝트 env).
# 값은 ~/.config/deskcloud-firebase.env 에 비커밋 보관. 미설정이면 인증이 비활성으로
# degrade 하고 빌드/런타임은 정상 동작합니다(authDomain/projectId 는 안전한 기본값 보유).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=deskcloud-fleet-auth.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=deskcloud-fleet-auth
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_SENDER_ID=
# VITE_FIREBASE_APP_ID=
