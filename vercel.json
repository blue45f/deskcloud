{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "corepack pnpm@11.4.0 install --no-frozen-lockfile --ignore-scripts",
  "buildCommand": "corepack pnpm@11.4.0 run build:platform-web-with-termsdesk",
  "outputDirectory": "platform/apps/web/dist",
  "rewrites": [
    {
      "source": "/termsdesk/api/:path*",
      "destination": "https://3.107.235.143.nip.io/api/:path*"
    },
    {
      "source": "/termsdesk/socket.io/:path*",
      "destination": "https://3.107.235.143.nip.io/socket.io/:path*"
    },
    {
      "source": "/termsdesk/sitemap.xml",
      "destination": "https://3.107.235.143.nip.io/api/public/sitemap.xml"
    },
    { "source": "/termsdesk/:path*", "destination": "/termsdesk/index.html" },
    {
      "source": "/seo-gateway/:path*",
      "destination": "https://16.176.210.195.nip.io/seo-gateway/:path*"
    },
    {
      "source": "/remote-devtools/:path*",
      "destination": "https://16.176.210.195.nip.io/remote-devtools/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://16.176.210.195.nip.io/platform/api/:path*"
    },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
