# ════════════════════════════════════════════════════════════════════════════
#  DeskCloud 배포 환경변수 — `cp .env.example .env` 후 값을 채우세요.
#  강한 ADMIN_TOKEN 은 `./gen-env.sh` 로 자동 생성할 수 있습니다(.env 새로 만듦).
# ════════════════════════════════════════════════════════════════════════════

# ── 게이트웨이 ───────────────────────────────────────────────────────────────
# 도메인을 설정하면 Caddy 가 자동 HTTPS(Let's Encrypt)를 발급합니다.
# 비워 두면 평문 HTTP(:80)로 동작합니다(로컬·IP 직접 접속).
#   예) DESKCLOUD_DOMAIN=desk.example.com
DESKCLOUD_DOMAIN=
ACME_EMAIL=ops@example.com

# 호스트 포트 매핑(다른 서비스와 충돌 시 변경 — 예: termsdesk EC2 공동배치).
HTTP_PORT=80
HTTPS_PORT=443

# 모든 Desk API 가 CORS/쿠키에 사용할 기본 출처. 도메인이 있으면 https://<도메인>.
#   예) WEB_ORIGIN=https://desk.example.com
WEB_ORIGIN=http://localhost

TZ=Asia/Seoul

# 로컬/소형 VM 에서 여러 Desk API 를 함께 띄울 때 시작 피크를 제한합니다.
DESK_API_MEM_LIMIT=8g
NODE_OPTIONS=--max-old-space-size=512

# ── per-Desk ADMIN_TOKEN (X-Admin-Token 헤더와 일치해야 어드민 API 통과) ──────
# 반드시 강한 무작위 값으로 교체하세요. `./gen-env.sh` 가 openssl 로 생성합니다.
SURVEYDESK_ADMIN_TOKEN=__replace_with_strong_random__
ADDESK_ADMIN_TOKEN=__replace_with_strong_random__
AUTHDESK_ADMIN_TOKEN=__replace_with_strong_random__
FILEDESK_ADMIN_TOKEN=__replace_with_strong_random__
CHANGELOGDESK_ADMIN_TOKEN=__replace_with_strong_random__
REVIEWDESK_ADMIN_TOKEN=__replace_with_strong_random__
MEDIADESK_ADMIN_TOKEN=__replace_with_strong_random__
NOTIFYDESK_ADMIN_TOKEN=__replace_with_strong_random__
MODERATIONDESK_ADMIN_TOKEN=__replace_with_strong_random__
REALTIMEDESK_ADMIN_TOKEN=__replace_with_strong_random__
SEARCHDESK_ADMIN_TOKEN=__replace_with_strong_random__
COMMUNITYDESK_ADMIN_TOKEN=__replace_with_strong_random__
CHATDESK_ADMIN_TOKEN=__replace_with_strong_random__
DESKPLATFORM_ADMIN_TOKEN=__replace_with_strong_random__

# lean Desk 별 secret-key/JWT 페퍼. 운영에서는 강한 무작위 값으로 교체하세요.
ADDESK_KEY_PEPPER=__replace_with_strong_random__
AUTHDESK_KEY_PEPPER=__replace_with_strong_random__
AUTHDESK_JWT_SECRET=__replace_with_strong_random__
FILEDESK_KEY_PEPPER=__replace_with_strong_random__

# 새 Desk 추가 시:
# FOODESK_ADMIN_TOKEN=__replace_with_strong_random__

# ── (선택) 빌링 — @desk/platform 은 TEST/STUB 어댑터만. 실제 결제 없음 ────────
DESK_BILLING_PROVIDER=stub

# ── (선택) per-Desk 외부 DB 전환 ─────────────────────────────────────────────
# 비워 두면 PGlite 임베드(외부 DB 불필요, 전용 볼륨에 영구 저장)를 씁니다.
# Neon/PostgreSQL 로 전환하려면 해당 Desk 의 DATABASE_URL 에 연결 문자열을 넣으세요.
#   예) SURVEYDESK_DATABASE_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/surveydesk?sslmode=require
# SURVEYDESK_DATABASE_URL=
# ADDESK_DATABASE_URL=
# AUTHDESK_DATABASE_URL=
# FILEDESK_DATABASE_URL=
# CHANGELOGDESK_DATABASE_URL=
# REVIEWDESK_DATABASE_URL=
# MEDIADESK_DATABASE_URL=
# NOTIFYDESK_DATABASE_URL=
# MODERATIONDESK_DATABASE_URL=
# REALTIMEDESK_DATABASE_URL=
# SEARCHDESK_DATABASE_URL=
# COMMUNITYDESK_DATABASE_URL=
# CHATDESK_DATABASE_URL=
# DESKPLATFORM_DATABASE_URL=
