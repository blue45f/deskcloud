# deploy/aws/.env — `cp .env.example .env` 후 값을 채우세요.
# (user-data.sh 로 부팅하면 이 파일은 공인IP·무작위 시크릿으로 자동 생성됩니다.)

# 도메인(이 VM의 공인 IP를 가리키는 A 레코드) — Caddy 가 자동 HTTPS 발급
DOMAIN=terms.example.com
ACME_EMAIL=ops@example.com

# Postgres
POSTGRES_USER=termsdesk
POSTGRES_DB=termsdesk
POSTGRES_PASSWORD=__강한_무작위_값__

# API
JWT_SECRET=__openssl_rand_hex_32__
SEED_ADMIN_EMAIL=admin@your-company.com
SEED_ADMIN_PASSWORD=__최초_관리자_비밀번호__

# (선택) Postgres 튜닝 — VM 메모리에 맞춰 조정
# PG_SHARED_BUFFERS=512MB
# PG_EFFECTIVE_CACHE=1536MB
# PG_WORK_MEM=8MB
# PG_MAX_CONN=50
